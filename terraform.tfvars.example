##############################################################################
# IBM Cloud Resource Groups - Example Variables File
#
# Copy this file to terraform.tfvars and update with your values
# Command: cp terraform.tfvars.example terraform.tfvars
#
# IMPORTANT: Never commit terraform.tfvars to version control as it contains
# sensitive information like API keys.
##############################################################################

##############################################################################
# IBM Cloud Authentication
##############################################################################

# Your IBM Cloud API Key
# Get your API key from: https://cloud.ibm.com/iam/apikeys
ibmcloud_api_key = "your-ibm-cloud-api-key-here"

##############################################################################
# Region Configuration
##############################################################################

# IBM Cloud region for provider configuration
# Valid regions: us-south, us-east, eu-gb, eu-de, jp-tok, jp-osa, au-syd, ca-tor, br-sao, eu-es
region = "us-south"

##############################################################################
# Resource Groups Configuration
##############################################################################

# Default resource groups configuration for IBM Cloud infrastructure
resource_groups = [
  {
    name = "powervs",
    tags = ["environment:powervs"]
  },
  {
    name = "vpc",
    tags = ["environment:vpc"]
  },
  {
    name = "cos",
    tags = ["environment:cos"]
  },
  {
    name = "log",
    tags = ["environment:log"]
  }
]

